# Urban proxy module — optional overrides (copy to ../.env or export before make up)
# Root reNgine .env (POSTGRES_*, DOMAIN_NAME, ...) is required at repo root.

# Parallel credential fetch workers (default: 20)
URBAN_PROXY_WORKERS=20

# Refresh interval in minutes (default: 25; Urban credentials ~30 min TTL)
URBAN_PROXY_INTERVAL=25

# Auto-enable Use Proxy in reNgine when proxies are synced (default: true)
AUTO_ENABLE_PROXY=true

# Docker Compose project name — must match reNgine stack (default: folder name, e.g. rengine)
# COMPOSE_PROJECT_NAME=rengine
